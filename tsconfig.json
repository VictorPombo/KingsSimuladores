{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022", "dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "*.ts",
    "*.js",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "apps",
    "packages",
    "dist",
    "build",
    "tests",
    ".claude",
    ".turbo"
  ]
}