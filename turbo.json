{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env.local"],
  "globalEnv": [
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "NEXT_PUBLIC_SITE_URL",
    "MP_ACCESS_TOKEN",
    "MP_PUBLIC_KEY",
    "FRENET_TOKEN",
    "FRENET_SANDBOX",
    "OLIST_ACCESS_TOKEN",
    "RESEND_API_KEY",
    "RESEND_FROM_KINGS",
    "RESEND_FROM_MSU",
    "CRON_SECRET",
    "MP_ACCESS_TOKEN_SEVEN",
    "OLIST_API_KEY_SEVEN",
    "CHAVE_API_IA",
    "MP_WEBHOOK_SECRET",
    "GEMINI_API_KEY",
    "FRENET_TOKEN_SEVEN",
    "FRENET_TOKEN_KINGS",
    "FRENET_CEP_ORIGEM_KINGS",
    "FRENET_CEP_ORIGEM_SEVEN"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "dependsOn": ["^type-check"]
    },
    "clean": {
      "cache": false
    }
  }
}
